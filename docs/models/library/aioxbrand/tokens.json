{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "AIOX Brand — Design Tokens",
    "version": "2.0.0",
    "source": "https://brand.aioxsquad.ai/ dissection",
    "date": "2026-03-17",
    "edition": "Dark Cockpit Edition",
    "themes": ["lime", "gold"]
  },

  "color": {
