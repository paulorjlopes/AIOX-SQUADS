      "border-hover": { "$value": "rgba(156, 156, 156, 0.24)", "$type": "color", "$description": "Interactive feedback" },
      "border-input": { "$value": "rgba(156, 156, 156, 0.20)", "$type": "color", "$description": "Form border" },
      "input": { "$value": "{color.semantic.border-input}", "$type": "color", "$description": "Input borders" },
      "ring": { "$value": "rgba(209, 255, 0, 0.4)", "$type": "color", "$description": "Focus ring" },
      "card": { "$value": "{color.primitive.lime.surface}", "$type": "color", "$description": "Card bg" },
      "card-foreground": { "$value": "{color.primitive.lime.cream}", "$type": "color", "$description": "Card text" },
