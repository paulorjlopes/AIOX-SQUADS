    "opacity-ladder": {
      "accent-02": { "$value": 0.02, "$type": "number" },
      "accent-04": { "$value": 0.04, "$type": "number" },
      "accent-05": { "$value": 0.05, "$type": "number" },
      "accent-06": { "$value": 0.06, "$type": "number" },
      "accent-08": { "$value": 0.08, "$type": "number" },
      "accent-10": { "$value": 0.10, "$type": "number" },
      "accent-12": { "$value": 0.12, "$type": "number" },
      "accent-15": { "$value": 0.15, "$type": "number" },
      "accent-20": { "$value": 0.20, "$type": "number" },
      "accent-25": { "$value": 0.25, "$type": "number" },
      "accent-40": { "$value": 0.40, "$type": "number" },
      "accent-50": { "$value": 0.50, "$type": "number" },
      "accent-75": { "$value": 0.75, "$type": "number" },
      "accent-90": { "$value": 0.90, "$type": "number" }
    },
    "contrast-pairs": {
      "lime": [
        { "fg": "--bb-lime", "bg": "--bb-dark", "label": "Lime / Dark" },
        { "fg": "--bb-cream", "bg": "--bb-canvas", "label": "Cream / Canvas" },
        { "fg": "--bb-dark", "bg": "--bb-lime", "label": "Dark / Lime" },
        { "fg": "--bb-blue", "bg": "--bb-dark", "label": "Blue / Dark" }
      ],
      "gold": [
        { "fg": "--bb-lime", "bg": "--bb-dark", "label": "Gold / Dark" },
        { "fg": "--bb-cream", "bg": "--bb-canvas", "label": "Cream / Canvas" },
        { "fg": "--bb-ink", "bg": "--bb-lime", "label": "Ink / Gold" },
        { "fg": "--bb-gray-silver", "bg": "--bb-surface", "label": "Silver / Surface" }
      ]
    }
  },

  "typography": {
    "family": {
      "display": { "$value": "TASAOrbiterDisplay, system-ui, sans-serif", "$type": "fontFamily", "$description": "--font-bb-display // Weight 800 // H1-H4, Titles, Impact" },
      "sans": { "$value": "Geist, system-ui, sans-serif", "$type": "fontFamily", "$description": "--font-bb-sans // Weight 400-700 // Body, UI, Labels" },
      "mono": { "$value": "RobotoMono, GeistMono, monospace", "$type": "fontFamily", "$description": "--font-bb-mono // Weight 400-500 // Code, Labels, Nav, HUD" }
    },
    "scale": {
      "display": { "$value": "4rem", "$type": "dimension", "$description": "Display — AIOX brand mark, hero statements" },
      "h1": { "$value": "2.5rem", "$type": "dimension", "$description": "H1 — Page titles" },
      "h2": { "$value": "1.5rem", "$type": "dimension", "$description": "H2 — Section titles" },
      "body": { "$value": "1rem", "$type": "dimension", "$description": "Body — Base reading size (16px)" },
      "small": { "$value": "0.8rem", "$type": "dimension", "$description": "Small — Secondary text, descriptions" },
      "label": { "$value": "0.65rem", "$type": "dimension", "$description": "Label — HUD labels, navigation, status" },
      "micro": { "$value": "0.6rem", "$type": "dimension", "$description": "Micro — Footer meta, class names, refs" }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "number" },
      "medium": { "$value": 500, "$type": "number" },
      "semibold": { "$value": 600, "$type": "number" },
      "bold": { "$value": 700, "$type": "number" },
      "black": { "$value": 800, "$type": "number" }
    },
    "letterSpacing": {
      "tight": { "$value": "-1.2px", "$type": "dimension", "$description": "Display headings" },
      "normal": { "$value": "0", "$type": "dimension", "$description": "Body text" },
      "wide": { "$value": "0.24px", "$type": "dimension", "$description": "Nav links" },
      "wider": { "$value": "1.3px", "$type": "dimension", "$description": "HUD labels, uppercase mono" }
    }
  },

  "spacing": {
    "radius": {
      "sm": { "$value": "4px", "$type": "dimension" },
      "md": { "$value": "8px", "$type": "dimension" },
      "default": { "$value": "0.5rem", "$type": "dimension" },
      "lg": { "$value": "12px", "$type": "dimension" },
      "xl": { "$value": "16px", "$type": "dimension" },
      "2xl": { "$value": "24px", "$type": "dimension" },
      "full": { "$value": "9999px", "$type": "dimension" }
    },
    "glass": {
      "blur": { "$value": "10px", "$type": "dimension" },
      "blur-soft": { "$value": "5px", "$type": "dimension" }
    }
  },

  "elevation": {
    "layer": {
      "base": { "$value": 0, "$type": "number", "$description": "Default stacking" },
      "elevated": { "$value": 1, "$type": "number", "$description": "Slightly raised" },
      "sticky": { "$value": 10, "$type": "number", "$description": "Sticky elements" },
      "nav": { "$value": 100, "$type": "number", "$description": "Navigation" },
      "dropdown": { "$value": 200, "$type": "number", "$description": "Dropdown menus" },
      "overlay": { "$value": 300, "$type": "number", "$description": "Overlays" },
      "modal": { "$value": 400, "$type": "number", "$description": "Modals" },
      "toast": { "$value": 500, "$type": "number", "$description": "Toast notifications" }
    }
  },

  "motion": {
    "keyframes": {
      "bb-ticker": { "$description": "Ticker/marquee horizontal scroll" },
      "spin": { "$description": "360deg rotation for spinners" },
      "ping": { "$description": "Scale + opacity pulse for notifications" },
      "pulse": { "$description": "Opacity breathing for loading states" },
      "enter": { "$description": "Element enter animation (opacity + transform)" },
      "exit": { "$description": "Element exit animation (opacity + transform)" },
      "accordion-down": { "$description": "Accordion expand (height: 0 → auto)" },
      "accordion-up": { "$description": "Accordion collapse (height: auto → 0)" }
    }
  }
}
