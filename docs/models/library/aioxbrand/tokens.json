        "accent": { "$value": "oklch(0.934 0.2264 121.95)", "$type": "color", "$description": "Primary accent. CTA, active states, emphasis, kinetic highlights" },
        "blue": { "$value": "oklch(0.669 0.1837 248.81)", "$type": "color", "$description": "Info accent. Secondary feedback and utility cues" },
        "flare": { "$value": "oklch(0.631 0.2116 36.21)", "$type": "color", "$description": "Warm counter-accent. Editorial heat and alerts" },
        "error": { "$value": "oklch(0.6368 0.2078 25.33)", "$type": "color", "$description": "Destructive/error state. Validation and danger cues" },
        "canvas": { "$value": "var(--bb-dark)", "$type": "color", "$description": "Document canvas. Main route background" },
        "dark": { "$value": "oklch(0.1149 0 0)", "$type": "color", "$description": "Dark shell. Hero panels, editorial density, hard contrast" },
        "surface": { "$value": "oklch(0.1693 0.0041 285.95)", "$type": "color", "$description": "Primary raised surface. Cards, top bars, shell modules" },
        "surface-alt": { "$value": "oklch(0.231 0.0099 124.97)", "$type": "color", "$description": "Secondary surface. Nested blocks and alternate rows" },
        "surface-panel": { "$value": "oklch(0.1785 0.0041 285.98)", "$type": "color", "$description": "Panel shell. Sidebars, drawers, utility layers" },
        "surface-console": { "$value": "oklch(0.184 0.0081 118.61)", "$type": "color", "$description": "Console/terminal zone. Utility output and mono previews" },
        "surface-hover-strong": { "$value": "oklch(0.1971 0.006 285.84)", "$type": "color", "$description": "Heavy hover state. Controls and selected shells" },
        "cream": { "$value": "oklch(0.9639 0.0158 106.69)", "$type": "color", "$description": "Primary reading color. Headlines and body text" },
        "cream-alt": { "$value": "oklch(0.9644 0.0172 103.15)", "$type": "color", "$description": "Soft alternate off-white. UI variants and large fields" },
        "warm-white": { "$value": "oklch(0.9952 0.0235 106.82)", "$type": "color", "$description": "Purest light. Mark/logo and maximum contrast details" },
        "dim": { "$value": "rgba(245, 244, 231, 0.4)", "$type": "color", "$description": "Muted copy. Labels, captions, secondary descriptions" },
        "muted": { "$value": "oklch(0.7952 0 0)", "$type": "color", "$description": "Neutral light support. Tertiary text and subtle separators" },
        "meta": { "$value": "oklch(0.6927 0 0)", "$type": "color", "$description": "Metadata color. Counters, supporting UI, technical labels" }
      },
      "gold": {
        "accent": { "$value": "#DDD1BB", "$type": "color", "$description": "Primary gold accent. Active states, badges, premium highlights" },
        "blue": { "$value": "oklch(0.669 0.1837 248.81)", "$type": "color", "$description": "Info accent. Preserved for shared system semantics" },
        "flare": { "$value": "#C4B7A2", "$type": "color", "$description": "Warm support accent. Secondary emphasis and richer highlights" },
        "error": { "$value": "oklch(0.6368 0.2078 25.33)", "$type": "color", "$description": "Destructive/error state. Shared semantic warning language" },
        "canvas": { "$value": "#09090A", "$type": "color", "$description": "Document canvas. Neutral black foundation for the edition" },
        "dark": { "$value": "#121213", "$type": "color", "$description": "Dark shell. Major panels and editorial contrast zones" },
        "surface": { "$value": "#151517", "$type": "color", "$description": "Primary elevated surface. Cards, nav, foundation blocks" },
        "surface-alt": { "$value": "#1D1D20", "$type": "color", "$description": "Alternate surface. Nested layers and secondary grouping" },
        "surface-panel": { "$value": "#18181B", "$type": "color", "$description": "Panel shell. Drawers, sidebars, supporting containers" },
        "surface-console": { "$value": "#222225", "$type": "color", "$description": "Dark utility console. Dense technical and mono moments" },
        "surface-hover-strong": { "$value": "#28282C", "$type": "color", "$description": "Strong hover/selection shell. Elevated interactivity" },
        "cream": { "$value": "#F4F4F4", "$type": "color", "$description": "Primary text. Clean neutral reading layer" },
        "cream-alt": { "$value": "#E8E8E8", "$type": "color", "$description": "Alternate light neutral. Secondary fields and tonal variation" },
        "warm-white": { "$value": "#FFFFFF", "$type": "color", "$description": "Maximum contrast white. Marks and highest-priority detail" },
        "dim": { "$value": "rgba(244, 244, 244, 0.52)", "$type": "color", "$description": "Muted copy. Supporting metadata and low-emphasis body" },
        "muted": { "$value": "#DDDDDD", "$type": "color", "$description": "Soft neutral. Utility text and quiet secondary layers" },
        "meta": { "$value": "#AFAFAF", "$type": "color", "$description": "Metadata color. Counters, labels, informational chrome" }
      },
      "neutral": {
        "gray-charcoal": { "$value": "oklch(0.36 0 0)", "$type": "color", "$description": "Heavy neutral. Utility fills and strong separators" },
