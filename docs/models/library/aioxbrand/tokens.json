        "gray-muted": { "$value": "oklch(0.683 0 0)", "$type": "color", "$description": "Muted support. Soft chip fills and subdued UI" },
        "gray-silver": { "$value": "oklch(0.7984 0 0)", "$type": "color", "$description": "Light neutral. Delicate fills and border-led components" },
        "muted-legacy": { "$value": "oklch(0.5173 0 0)", "$type": "color", "$description": "Legacy neutral bridge. Compatibility layers" }
      },
      "status": {
        "success": { "$value": "oklch(0.8003 0.1821 151.71)", "$type": "color" },
        "warning": { "$value": "oklch(0.8369 0.1644 84.43)", "$type": "color" },
        "error": { "$value": "oklch(0.7106 0.1661 22.22)", "$type": "color" },
        "info": { "$value": "oklch(0.7137 0.1434 254.62)", "$type": "color" }
      }
    },
    "semantic": {
      "background": { "$value": "{color.primitive.lime.canvas}", "$type": "color", "$description": "Page background" },
      "foreground": { "$value": "{color.primitive.lime.cream}", "$type": "color", "$description": "Default text" },
      "primary": { "$value": "{color.primitive.lime.accent}", "$type": "color", "$description": "Primary actions" },
      "primary-foreground": { "$value": "{color.primitive.lime.dark}", "$type": "color", "$description": "Text on primary" },
