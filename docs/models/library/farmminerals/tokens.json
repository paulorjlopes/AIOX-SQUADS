{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Farm Minerals Pattern — Design Tokens",
    "version": "1.0.0",
    "source": "farmminerals.com dissection",
    "date": "2026-03-17"
  },
  "color": {
    "primitive": {
      "green-900": { "$value": "#2A3318", "$type": "color" },
      "green-800": { "$value": "#3B4A23", "$type": "color" },
      "green-700": { "$value": "#4A5A2B", "$type": "color" },
      "green-600": { "$value": "#5C6B3A", "$type": "color" },
      "green-500": { "$value": "#6E7D4C", "$type": "color" },
      "green-400": { "$value": "#8A9668", "$type": "color" },
      "green-300": { "$value": "#A8B48A", "$type": "color" },
      "green-200": { "$value": "#C5CEAF", "$type": "color" },
      "green-100": { "$value": "#E2E7D5", "$type": "color" },
      "cream-100": { "$value": "#F5F0E8", "$type": "color" },
      "cream-200": { "$value": "#EDE8DD", "$type": "color" },
      "cream-300": { "$value": "#E0D9CC", "$type": "color" },
      "white": { "$value": "#FFFFFF", "$type": "color" },
      "black": { "$value": "#1A1A1A", "$type": "color" },
      "gray-600": { "$value": "#4A4A4A", "$type": "color" },
      "gray-400": { "$value": "#8A8A8A", "$type": "color" },
      "gray-200": { "$value": "#D0D0D0", "$type": "color" }
    },
    "semantic": {
      "surface-primary": { "$value": "{color.primitive.cream-100}", "$type": "color" },
      "surface-secondary": { "$value": "{color.primitive.green-700}", "$type": "color" },
      "surface-dark": { "$value": "{color.primitive.green-900}", "$type": "color" },
      "surface-white": { "$value": "{color.primitive.white}", "$type": "color" },
      "text-primary": { "$value": "{color.primitive.black}", "$type": "color" },
      "text-on-dark": { "$value": "{color.primitive.cream-100}", "$type": "color" },
      "text-secondary": { "$value": "{color.primitive.gray-600}", "$type": "color" },
      "text-muted": { "$value": "{color.primitive.gray-400}", "$type": "color" },
      "accent-primary": { "$value": "{color.primitive.green-600}", "$type": "color" },
      "accent-hover": { "$value": "{color.primitive.green-500}", "$type": "color" },
      "border-default": { "$value": "{color.primitive.gray-200}", "$type": "color" },
      "border-subtle": { "$value": "{color.primitive.cream-300}", "$type": "color" }
    }
  },
  "typography": {
    "family": {
      "heading": { "$value": "'Editorial New', Georgia, 'Times New Roman', serif", "$type": "fontFamily" },
      "body": { "$value": "'Inter', 'Helvetica Neue', Arial, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "'JetBrains Mono', 'Fira Code', monospace", "$type": "fontFamily" }
    },
    "scale": {
      "display": {
        "fontSize": { "$value": "clamp(3rem, 8vw, 7rem)", "$type": "dimension" },
        "fontWeight": { "$value": 400, "$type": "fontWeight" },
        "lineHeight": { "$value": 0.95, "$type": "number" },
        "letterSpacing": { "$value": "-0.03em", "$type": "dimension" }
      },
      "h1": {
        "fontSize": { "$value": "clamp(2.5rem, 6vw, 5rem)", "$type": "dimension" },
        "fontWeight": { "$value": 400, "$type": "fontWeight" },
        "lineHeight": { "$value": 1.0, "$type": "number" },
        "letterSpacing": { "$value": "-0.02em", "$type": "dimension" }
      },
      "h2": {
        "fontSize": { "$value": "clamp(1.75rem, 3.5vw, 3rem)", "$type": "dimension" },
        "fontWeight": { "$value": 400, "$type": "fontWeight" },
        "lineHeight": { "$value": 1.1, "$type": "number" },
        "letterSpacing": { "$value": "-0.01em", "$type": "dimension" }
      },
      "h3": {
        "fontSize": { "$value": "clamp(1.25rem, 2vw, 1.75rem)", "$type": "dimension" },
        "fontWeight": { "$value": 500, "$type": "fontWeight" },
        "lineHeight": { "$value": 1.2, "$type": "number" }
      },
      "body-lg": {
        "fontSize": { "$value": "1.125rem", "$type": "dimension" },
        "fontWeight": { "$value": 400, "$type": "fontWeight" },
        "lineHeight": { "$value": 1.6, "$type": "number" }
      },
      "body": {
        "fontSize": { "$value": "1rem", "$type": "dimension" },
        "fontWeight": { "$value": 400, "$type": "fontWeight" },
        "lineHeight": { "$value": 1.65, "$type": "number" }
      },
      "body-sm": {
        "fontSize": { "$value": "0.875rem", "$type": "dimension" },
        "fontWeight": { "$value": 400, "$type": "fontWeight" },
        "lineHeight": { "$value": 1.5, "$type": "number" }
      },
      "caption": {
        "fontSize": { "$value": "0.75rem", "$type": "dimension" },
        "fontWeight": { "$value": 500, "$type": "fontWeight" },
        "lineHeight": { "$value": 1.4, "$type": "number" },
        "letterSpacing": { "$value": "0.05em", "$type": "dimension" },
        "textTransform": { "$value": "uppercase", "$type": "textTransform" }
      }
    }
  },
  "spacing": {
    "0": { "$value": "0", "$type": "dimension" },
    "1": { "$value": "0.25rem", "$type": "dimension" },
    "2": { "$value": "0.5rem", "$type": "dimension" },
    "3": { "$value": "0.75rem", "$type": "dimension" },
    "4": { "$value": "1rem", "$type": "dimension" },
    "6": { "$value": "1.5rem", "$type": "dimension" },
    "8": { "$value": "2rem", "$type": "dimension" },
    "12": { "$value": "3rem", "$type": "dimension" },
    "16": { "$value": "4rem", "$type": "dimension" },
    "20": { "$value": "5rem", "$type": "dimension" },
    "24": { "$value": "6rem", "$type": "dimension" },
    "32": { "$value": "8rem", "$type": "dimension" },
    "48": { "$value": "12rem", "$type": "dimension" },
    "section-gap": { "$value": "clamp(4rem, 10vw, 8rem)", "$type": "dimension" },
    "container-max": { "$value": "1280px", "$type": "dimension" },
    "container-padding": { "$value": "clamp(1rem, 5vw, 3rem)", "$type": "dimension" }
  },
  "motion": {
    "duration": {
      "instant": { "$value": "100ms", "$type": "duration" },
      "fast": { "$value": "200ms", "$type": "duration" },
      "normal": { "$value": "400ms", "$type": "duration" },
      "slow": { "$value": "600ms", "$type": "duration" },
      "dramatic": { "$value": "1000ms", "$type": "duration" }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(0.25, 0.1, 0.25, 1)", "$type": "cubicBezier" },
      "enter": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "exit": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
      "bounce": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" },
      "smooth": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" }
    },
    "stagger": {
      "children": { "$value": "50ms", "$type": "duration" },
      "words": { "$value": "30ms", "$type": "duration" },
      "letters": { "$value": "20ms", "$type": "duration" }
    }
  },
  "breakpoints": {
    "mobile": { "$value": "0px", "$type": "dimension" },
    "tablet": { "$value": "768px", "$type": "dimension" },
    "desktop": { "$value": "1024px", "$type": "dimension" },
    "wide": { "$value": "1440px", "$type": "dimension" },
    "ultra": { "$value": "1920px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0", "$type": "dimension" },
    "sm": { "$value": "0.25rem", "$type": "dimension" },
    "md": { "$value": "0.5rem", "$type": "dimension" },
    "lg": { "$value": "1rem", "$type": "dimension" },
    "xl": { "$value": "1.5rem", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px 0 rgba(0,0,0,0.05)", "$type": "shadow" },
    "md": { "$value": "0 4px 6px -1px rgba(0,0,0,0.1)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px -3px rgba(0,0,0,0.1)", "$type": "shadow" }
  }
}
