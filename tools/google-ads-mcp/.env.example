# Google Ads API Credentials
# Get from: Google Cloud Console > APIs & Services > Credentials

# OAuth2 credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Google Ads Developer Token
# Get from: Google Ads > Tools & Settings > API Center
GOOGLE_DEVELOPER_TOKEN=your_developer_token_here

# MCC (Manager Account) Customer ID (without dashes, e.g., 1234567890)
# All child accounts will be accessible via google_list_accounts tool
GOOGLE_CUSTOMER_ID=your_mcc_customer_id_here

# Optional: Login Customer ID (usually same as MCC ID)
GOOGLE_LOGIN_CUSTOMER_ID=
