# Meta Marketing API Credentials
# Get from: developers.facebook.com > Your App > Tools > Graph API Explorer
META_ACCESS_TOKEN=your_access_token_here

# Ad Account ID (without 'act_' prefix)
# Get from: Business Manager > Business Settings > Ad Accounts
META_AD_ACCOUNT_ID=your_ad_account_id_here

# Optional: App ID and Secret (for token refresh)
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
